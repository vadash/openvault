{
    "name": "openvault",
    "version": "5.00",
    "type": "module",
    "description": "SillyTavern memory extension",
    "scripts": {
        "clear": "node -e \"process.stdout.write('\\u001B[2J\\u001B[0;0f')\"",
        "prepare": "git config core.hooksPath .githooks",
        "lint": "biome check .",
        "lint:fix": "biome check --write --unsafe .",
        "format": "biome format --write .",
        "test": "node scripts/test.js",
        "sync-version": "node scripts/sync-version.js",
        "repomix": "npm run repomix:source && npm run repomix:tests",
        "repomix:source": "npx repomix --style markdown --output repomix-source.md --include \"README.md,CLAUDE.md,index.js,style.css,manifest.json,package.json,biome.json,vitest.config.js,src/**,include/**,scripts/**,templates/**\"",
        "repomix:tests": "npx repomix --style markdown --output repomix-tests.md --include \"tests/**\""
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4",
        "graphology": "^0.26.0",
        "graphology-communities-louvain": "^2.0.2",
        "graphology-operators": "^1.6.1",
        "jsdom": "^27.4.0",
        "jsonrepair": "^3.13.2",
        "repomix": "^0.3.2",
        "snowball-stemmers": "^0.6.0",
        "vitest": "^4.0.16"
    },
    "dependencies": {
        "gpt-tokenizer": "^3.4.0",
        "stopword": "^3.1.5",
        "zod": "^4.3.6"
    }
}
